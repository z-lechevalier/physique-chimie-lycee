	<question type="multichoice">
		<name>
			<text><![CDATA[]]></text>
		</name>
		<questiontext format="html">
			<text><![CDATA[<div style="font-family: Arial; font-size: 13px;">De méga à giga, par combien multiplie-t-on ?</div>]]></text>
		</questiontext>
		<externallink/>
		<usecase>1</usecase>
		<defaultgrade>1</defaultgrade>
		<single>true</single>
		<answer fraction="0" format="plain_text">
			<text><![CDATA[Par 10 seulement, comme pour le préfixe déca]]></text>
			<feedback>
				<text><![CDATA[]]></text>
			</feedback>
		</answer>
		<answer fraction="0" format="plain_text">
			<text><![CDATA[Par 100, comme on pourrait le croire à tort]]></text>
			<feedback>
				<text><![CDATA[]]></text>
			</feedback>
		</answer>
		<answer fraction="0" format="plain_text">
			<text><![CDATA[Par 3, en faisant la différence des exposants]]></text>
			<feedback>
				<text><![CDATA[]]></text>
			</feedback>
		</answer>
		<answer fraction="100" format="plain_text">
			<text><![CDATA[Par 1000, le saut habituel entre ces préfixes]]></text>
			<feedback>
				<text><![CDATA[De méga à giga : de 10 puissance 6 à 10 puissance 9, soit 1000 fois plus. Entre kilo, méga, giga et téra, le saut est toujours de 1000.]]></text>
			</feedback>
		</answer>
