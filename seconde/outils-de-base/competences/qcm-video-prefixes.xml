			<text><![CDATA[On multiplie (on va vers une unité plus grande)]]></text>
			<feedback>
				<text><![CDATA[]]></text>
			</feedback>
		</answer>
		<answer fraction="0" format="plain_text">
			<text><![CDATA[On ne change rien, c'est le même nombre]]></text>
			<feedback>
				<text><![CDATA[]]></text>
			</feedback>
		</answer>
		<answer fraction="0" format="plain_text">
			<text><![CDATA[On ajoute le nombre de zéros du préfixe]]></text>
			<feedback>
				<text><![CDATA[]]></text>
			</feedback>
		</answer>
