	<question type="multichoice">
		<name>
			<text><![CDATA[]]></text>
		</name>
		<questiontext format="html">
			<text><![CDATA[<div style="font-family: Arial; font-size: 13px;">Un fichier fait 5 Mo (avec un M majuscule). Que désigne le préfixe M ici ?</div>]]></text>
		</questiontext>
		<externallink/>
		<usecase>1</usecase>
		<defaultgrade>1</defaultgrade>
		<single>true</single>
		<answer fraction="0" format="plain_text">
			<text><![CDATA[Milli, soit 10 puissance moins 3]]></text>
			<feedback>
				<text><![CDATA[]]></text>
			</feedback>
		</answer>
		<answer fraction="100" format="plain_text">
			<text><![CDATA[Méga, soit 10 puissance 6]]></text>
			<feedback>
				<text><![CDATA[M majuscule = méga = 10 puissance 6. Avec un m minuscule, ce serait milli, mille fois plus petit.]]></text>
			</feedback>
		</answer>
		<answer fraction="0" format="plain_text">
			<text><![CDATA[Mètre, c'est l'unité de longueur]]></text>
			<feedback>
				<text><![CDATA[]]></text>
			</feedback>
		</answer>
		<answer fraction="0" format="plain_text">
			<text><![CDATA[Mini, un préfixe plus petit que l'unité]]></text>
			<feedback>
				<text><![CDATA[]]></text>
			</feedback>
		</answer>
		<tags>
			<tag>
				<text>compulsory</text>
			</tag>
		</tags>
	</question>
